<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pixcel.app.milestones.mapper.MilestonesMapper">
	    <!-- 팀 ID를 조건으로 해당 팀의 멤버 목록을 조회합니다 -->
    <select id="getManagerList" resultType="MilestonesMemberDTO">
	SELECT 
         p.PROJECT_ID       
        ,u.USER_ID             
        ,u.USER_NAME          
        ,p.ROLE_ID          
    FROM PROJECT_MEMBER p
    INNER JOIN TEAM_MEMBER t ON p.TEAM_MEMBER_ID = t.TEAM_MEMBER_ID
    INNER JOIN USERS u ON t.USER_ID = u.USER_ID  
    WHERE p.PROJECT_ID = #{projectId}                
    </select>
        <!-- 키워드 검색과 버전 필터링을 동시에 수행하는 동적 쿼리입니다 -->
	<select id="getIssueList" resultType="MilestonesIssueDTO">
    SELECT 
         i.ISSUE_ID      
        ,i.TITLE        
        ,i.VERSION_ID    
        ,i.PROGRESS_RATE 
    FROM ISSUE i
    WHERE (i.TITLE LIKE '%' || #{keyword} || '%' OR i.ISSUE_ID LIKE '%' || #{keyword} || '%')
    <!--통합 검색창 기능입니다. 사용자가 검색어(keyword)를 입력하면, 일감의 제목에 그 글자가 들어가 있거나 혹은 일감 고유 번호(ID)에 그 숫자가 들어가 있는 것을 동시에 찾습니다.-->
    <if test="versionId != null">
        AND i.VERSION_ID = #{versionId}
    </if>
    <!--마일스톤을 새로 만들 때(아직 아무 일감도 안 골랐을 때)는 versionId가 없으므로 이 조건이 넘어가서 모든 버전의 일감이 다 보입니다!-->
    AND i.MILESTONE_ID IS NULL
    <!--이미 다른 마일스톤에 소속되어 일하고 있는 일감은 새로 만드는 마일스톤 검색 결과에서 원천 배제합니다.-->
	</select>
    
        <!-- 오라클 프로시저를 호출하여 마일스톤 정보를 저장합니다 -->
    <!-- statementType="CALLABLE"은 프로시저 호출 시 반드시 명시해야 합니다 -->
	<insert id="insertMilestone" statementType="CALLABLE" parameterType="MilestonesCreateRequestDTO">
        { CALL PKG_MILESTONE.SP_INSERT_MILESTONE(
            #{title}, 
            #{description}, 
            #{managerId}, 
            #{statusCode}, 
            #{startDate}, 
            #{endDate}, 
            #{versionId}, 
            #{selectedIssueIds},
            #{milestoneId, mode=OUT, jdbcType=VARCHAR}
        ) }
    </insert>
    
    <select id="getMilestoneDetail" resultType="MilestonesCreateRequestDTO">
    	SELECT
    		a.milestone_id,
    		a.version_id,
    		a.title,
    		a.description,
    		a.manager_id,
    		b.user_name AS managerName, 
    		a.status_code,
    		a.status_name,
    		a.start_date,
    		a.end_date,
    		a.created_at
    	FROM milestone a
    	LEFT OUTER JOIN users b ON a.manager_id = b.user_id
    	WHERE a.milestone_id = #{milestoneId}
    </select>
    
      <update id="updateMilestone" statementType="CALLABLE" parameterType="MilestonesCreateRequestDTO">
        { CALL PKG_MILESTONE.SP_UPDATE_MILESTONE(
            #{milestoneId}, 
            #{title}, 
            #{description}, 
            #{managerId}, 
            #{statusCode}, 
            #{startDate}, 
            #{endDate}, 
            #{versionId}, 
            #{selectedIssueIds}
        ) }
    </update>
    <delete id="deleteMilestone" statementType="CALLABLE" parameterType="MilestonesVO">
    	{ CALL PKG_MILESTONE.SP_DELETE_MILESTONE(
            #{milestoneId}
        ) }
    </delete>
    
    <resultMap id="MilestoneListMap" type="MilestoneListResponseDTO">
        
        <id property="milestoneId" column="MILESTONE_ID"/>
        <result property="title" column="MILESTONE_TITLE"/>
        <result property="startDate" column="START_DATE"/>
        <result property="endDate" column="END_DATE"/>
        <result property="managerName" column="MANAGER_NAME"/> <result property="statusCode" column="STATUS_CODE"/>
        <result property="totalProgressRate" column="TOTAL_PROGRESS_RATE"/>

        <collection property="issueList" ofType="MilestonesIssueDTO">
            <id property="issueId" column="ISSUE_ID"/>
            <result property="title" column="ISSUE_TITLE"/>
            <result property="issueStatusId" column="ISSUE_STATUS_ID"/>
            <result property="description" column="ISSUE_DESCRIPTION"/>
            <result property="progressRate" column="ISSUE_PROGRESS_RATE"/>
        </collection>
        
    </resultMap>

    <select id="getMilestoneList" resultMap="MilestoneListMap" parameterType="MilestoneSearchVO">
        SELECT 
            -- 마일스톤 테이블 (M)
            M.MILESTONE_ID,
            M.TITLE AS MILESTONE_TITLE,
            M.START_DATE,
            M.END_DATE,
            M.STATUS_CODE,
            
            -- 유저 테이블 (U)에서 실제 담당자 이름 가져오기 ⭐️
            U.USER_NAME AS MANAGER_NAME, 
            
            -- 마일스톤 전체 진행률 (하위 일감들의 평균 진척도 계산)
            NVL((
                SELECT ROUND(AVG(PROGRESS_RATE)) 
                FROM ISSUE 
                WHERE MILESTONE_ID = M.MILESTONE_ID
            ), 0) AS TOTAL_PROGRESS_RATE,

            -- 일감 테이블 (I)
            I.ISSUE_ID,
            I.TITLE AS ISSUE_TITLE,
            I.ISSUE_STATUS_ID,
            I.DESCRIPTION AS ISSUE_DESCRIPTION,
            I.PROGRESS_RATE AS ISSUE_PROGRESS_RATE
            
        FROM MILESTONE M
        LEFT OUTER JOIN USERS U ON M.MANAGER_ID = U.USER_ID  
        LEFT OUTER JOIN ISSUE I ON M.MILESTONE_ID = I.MILESTONE_ID
        <where>
            <if test="startDate != null and startDate != '' and endDate != null and endDate != ''">
                AND M.START_DATE <![CDATA[>=]]> TO_DATE(#{startDate}, 'YYYY-MM-DD')
                AND M.END_DATE <![CDATA[<=]]> TO_DATE(#{endDate}, 'YYYY-MM-DD')
            </if>
            
            <if test="title != null and title != ''">
                AND M.TITLE LIKE '%' || #{title} || '%'
            </if>
            
            <if test="managerName != null and managerName != ''">
    			AND U.USER_NAME LIKE '%' || #{managerName} || '%'
			</if>
            
            <if test="statusCode != null and statusCode != ''">
                AND M.STATUS_CODE = #{statusCode}
            </if>
        </where>
        
        ORDER BY M.START_DATE DESC, I.ISSUE_ID ASC
    </select>

    <select id="selectConnectedIssues" resultType="MilestonesIssueDTO">
        SELECT 
        	 issue_id
        	,title
        	,version_id
        	,progress_rate
    	FROM ISSUE
    	WHERE MILESTONE_ID = #{milestoneId}
    </select>
    
</mapper>